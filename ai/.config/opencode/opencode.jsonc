{
  "$schema": "https://opencode.ai/config.json",
  "username": "Sierra",
  "theme": "catppuccin",
  "autoupdate": "notify",
  "default_agent": "plan",
  "share": "disabled",
  "keybinds": { "leader": "`" },
  "formatter": {
    "prettier": { "disabled": false },
    "eslint": { "disabled": false },
  },
  "compaction": { "auto": false, "prune": false },
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "mdns": false,
    // "cors": ["http://localhost:4096"]
  },
  "disabled_providers": ["cloudflare-ai-gateway"],
  "small_model": "github-copilot/gpt-5-mini",
  "agent": {
    "plan": {
      "model": "openai/gpt-5.2",
      "variant": "high",
    },
    "build": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
    },
    "explore": {
      "model": "openai/gpt-5.3-codex",
    },
    "compaction": {
      "model": "github-copilot/gemini-3.1-pro-preview",
    },
  },
  "permission": {
    "skill": {
      "*": "ask",
    },
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/keyfile.json": "deny",
      "**/.env.example": "allow",
      "**/.env.sample": "allow",
      "**/.example.env.file": "allow",
    },
    "bash": {
      // Default
      "*": "ask",
      // Allow
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "tree *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "ls *": "allow",
      "jq *": "allow",
      "bash -n *": "allow",
      "sed -n *": "allow",
      "wc -l *": "allow",
      "gh issue view *": "allow",
      "gh pr view *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "mise help *": "allow",
      "mise registry *": "allow",
      "docker status *": "allow",
      "docker ps *": "allow",
      // Deny
      "rm -rf /": "deny",
      "* .env*": "deny",
      "* .env": "deny",
      "* */.env*": "deny",
      "* */.env": "deny",
    },
    "edit": {
      "*": "ask",
    },
    "codesearch": "deny",
    "lsp": "allow",
    "grep": "allow",
    "list": "allow",
    "webfetch": "ask",
    "external_directory": {
      "/tmp/**": "allow",
    },
  },
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
    },
    "grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app",
    },
  },
}
